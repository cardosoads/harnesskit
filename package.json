{
  "name": "@cardosoads/harnesskit",
  "version": "0.1.3",
  "description": "Harness-first agent workflow scaffold for software projects.",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agents",
    "harness",
    "spec-driven",
    "workflow",
    "ai"
  ],
  "bin": {
    "harnesskit": "bin/harnesskit.mjs"
  },
  "files": [
    "bin/",
    ".claude/commands/",
    ".harnesskit/harnesskit.yaml",
    ".harnesskit/core/",
    ".harnesskit/harness/HARNESS.md",
    ".harnesskit/harness/feedforward.yaml",
    ".harnesskit/harness/sensors.yaml",
    ".harnesskit/harness/templates/",
    ".harnesskit/harness/baselines/README.md",
    ".harnesskit/harness/contracts/README.md",
    ".harnesskit/schemas/",
    ".harnesskit/scripts/harness-doctor.sh",
    ".harnesskit/scripts/harness-evaluate.sh",
    ".harnesskit/scripts/harness-selftest.sh",
    ".harnesskit/scripts/harness_doctor.py",
    ".harnesskit/scripts/harness_evaluate.py",
    ".harnesskit/scripts/harness_selftest.py",
    ".harnesskit/scripts/validate.sh",
    ".harnesskit/specs/",
    ".harnesskit/teams/",
    "scripts/check-package-files.mjs",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "scripts": {
    "harnesskit": "node bin/harnesskit.mjs",
    "validate": "bash .harnesskit/scripts/validate.sh",
    "test": "bash .harnesskit/scripts/validate.sh && bash .harnesskit/scripts/harness-selftest.sh",
    "pack:check": "node scripts/check-package-files.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/cardosoads/harnesskit.git"
  },
  "homepage": "https://github.com/cardosoads/harnesskit#readme",
  "bugs": {
    "url": "https://github.com/cardosoads/harnesskit/issues"
  },
  "dependencies": {
    "ajv-cli": "5.0.0"
  }
}
