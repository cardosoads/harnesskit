{
  "name": "overharness",
  "version": "0.1.0",
  "description": "Harness-first agent workflow scaffold for software projects.",
  "type": "module",
  "private": false,
  "keywords": [
    "agents",
    "harness",
    "spec-driven",
    "workflow",
    "ai"
  ],
  "bin": {
    "overharness": "bin/overharness.mjs"
  },
  "files": [
    "bin/",
    ".claude/commands/",
    ".overharness/core/",
    ".overharness/harness/HARNESS.md",
    ".overharness/harness/feedforward.yaml",
    ".overharness/harness/sensors.yaml",
    ".overharness/harness/templates/",
    ".overharness/harness/baselines/README.md",
    ".overharness/harness/contracts/README.md",
    ".overharness/schemas/",
    ".overharness/scripts/harness-doctor.sh",
    ".overharness/scripts/harness-evaluate.sh",
    ".overharness/scripts/harness-selftest.sh",
    ".overharness/scripts/harness_doctor.py",
    ".overharness/scripts/harness_evaluate.py",
    ".overharness/scripts/harness_selftest.py",
    ".overharness/scripts/validate.sh",
    ".overharness/specs/",
    ".overharness/teams/",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "scripts": {
    "overharness": "node bin/overharness.mjs",
    "validate": "bash .overharness/scripts/validate.sh",
    "test": "bash .overharness/scripts/validate.sh && bash .overharness/scripts/harness-selftest.sh",
    "pack:check": "npm pack --dry-run --json"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/cardosoads/overharness.git"
  },
  "homepage": "https://github.com/cardosoads/overharness#readme",
  "bugs": {
    "url": "https://github.com/cardosoads/overharness/issues"
  },
  "dependencies": {
    "ajv-cli": "5.0.0"
  }
}
